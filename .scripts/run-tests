set -eo pipefail
if [ -z "$VIRTUAL_ENV" ]; then
    source .venv/bin/activate
fi
mypy src
MYPYPATH=src mypy --namespace-packages --explicit-package-bases tests
# NOTE: do not modify these options without considering code-coverage impact.
cat tests/filters-file.txt | PYTHONPATH=src coverage run -m punit -p tests --trait '!integration' --trait '!hardcoded' --trait '!longrunning' --trait '!manual' --verbose --filter '@stdin' --include '*.py' --exclude 'jabba-have-a-wookie-cookie' -a fig newton "$@"
coverage report
